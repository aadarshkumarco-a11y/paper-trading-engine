# Copy this file to .env and fill in the values you actually use.
# The app works fully without any of these — they only enable real broker feeds.

# --- Zerodha Kite Connect (optional) ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# --- Angel One SmartAPI (optional) ---
# Library: https://github.com/angel-one/smartapi-python
# 1. `pip install smartapi-python pyotp`
# 2. Generate an API key at https://smartapi.angelbroking.com
# 3. ANGEL_TOTP_SECRET is the QR/setup-key shown when you enable 2FA. Store it
#    once; pyotp generates the rolling 6-digit code on every login.
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# --- App configuration ---
PAPER_TRADING_DB=runtime/paper_trading.db
PAPER_TRADING_LOG_LEVEL=INFO
PAPER_TRADING_DATA_FEED=yfinance   # yfinance | nse | kite | angel
